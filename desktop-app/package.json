{
  "name": "zlote-miody",
  "version": "1.0.0",
  "description": "Złote Miody — Naturalne miody prosto z pasieki (aplikacja desktopowa)",
  "main": "main.js",
  "author": "Złote Miody",
  "scripts": {
    "obfuscate": "javascript-obfuscator src --output . --target node --compact true --control-flow-flattening true --dead-code-injection true --identifier-names-generator hexadecimal --rename-globals true --string-array true --string-array-encoding 'base64' --string-array-calls-transform true",
    "prestart": "npm run obfuscate",
    "start": "electron .",
    "prebuild:mac": "npm run obfuscate",
    "build:mac": "electron-builder --mac",
    "prebuild:win": "npm run obfuscate",
    "build:win": "electron-builder --win",
    "prebuild:all": "npm run obfuscate",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "pl.zlote-miody.app",
    "productName": "Złote Miody",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "icon.png"
    ],
    "mac": {
      "category": "public.app-category.shopping",
      "icon": "icon.png",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Złote Miody",
      "icon": "icon.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 400
      }
    },
    "win": {
      "icon": "icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "Złote Miody"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "javascript-obfuscator": "^5.4.3"
  }
}
